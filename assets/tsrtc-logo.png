.quick-routes ul {
  list-style: none; /* Remove default list styling */
  padding: 0; /* Remove padding from the list */
  margin: 0; /* Remove margin from the list */
}

.quick-routes ul li {
  display: flex; /* Use flexbox for alignment */
  align-items: center; /* Vertically center align content */
  white-space: nowrap; /* Prevent text from wrapping */
  overflow: hidden; /* Hide overflow if the text is too long */
  text-overflow: ellipsis; /* Add ellipsis for long text */
}

.quick-routes ul li a {
  text-decoration: none; /* Remove underline from links */
  color: inherit; /* Use the inherited text color */
  display: inline-block; /* Ensure proper spacing */
  white-space: nowrap; /* Prevent text from wrapping */
}

.quick-routes ul li:first-child {
  font-weight: bold; /* Bold style for the "Quick Routes" title */
}

